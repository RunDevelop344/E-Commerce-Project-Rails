<div class="container py-4" style="max-width: 700px;">
  <h2 class="mb-4">Checkout — Order Summary</h2>

  <table class="table table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Product</th>
        <th>Qty</th>
        <th>Unit Price</th>
        <th>Subtotal</th>
      </tr>
    </thead>
    <tbody>
      <% @cart_items.each do |item| %>
        <tr>
          <td><%= item[:product].name %></td>
          <td><%= item[:quantity] %></td>
          <td>$<%= "%.2f" % item[:product].price %></td>
          <td>$<%= "%.2f" % item[:subtotal] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= form_with url: checkout_path, method: :post, local: true do |f| %>

    <%# Province selection if user has no province %>
    <% if current_user.province.nil? %>
      <div class="mb-3">
        <label class="form-label fw-bold">Select your province for tax calculation</label>
        <%= select_tag :province_id, options_from_collection_for_select(Province.all.order(:name), :id, :name),
            { include_blank: "Select Province", class: "form-select",
              onchange: "this.form.submit()" } %>
      </div>
    <% else %>
      <%= hidden_field_tag :province_id, current_user.province_id %>
    <% end %>

    <%# Address if unknown %>
     <% if current_user.address.blank? %>
     <%= render "checkouts/address_form", f: f %>
    <% end %>

    <%# Tax summary %>
<%= render "checkouts/invoice_summary",
    subtotal: @subtotal,
    gst: @gst,
    pst: @pst,
    hst: @hst,
    province: @province,
    total: @total %>


    <div class="d-grid">
      <%= f.submit "Place Order", class: "btn btn-success btn-lg" %>
    </div>
  <% end %>
</div>