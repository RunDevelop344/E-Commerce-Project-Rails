<div class="container mt-5" style="max-width: 600px;">
  <h2 class="mb-4">Edit Account</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="row mb-3">
      <div class="col-md-6">
        <%= f.label :first_name, class: "form-label" %>
        <%= f.text_field :first_name, class: "form-control", autocomplete: "given-name" %>
      </div>
      <div class="col-md-6">
        <%= f.label :last_name, class: "form-label" %>
        <%= f.text_field :last_name, class: "form-control", autocomplete: "family-name" %>
      </div>
    </div>

    <div class="mb-3">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="form-text text-warning">Currently waiting confirmation for: <%= resource.unconfirmed_email %></div>
      <% end %>
    </div>

    <hr class="my-4">
    <h3 class="mb-3">Address Details</h3>

    <div class="mb-3">
      <%= f.label :address, "Street Address", class: "form-label" %>
      <%= f.text_field :address, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :city, class: "form-label" %>
      <%= f.text_field :city, class: "form-control", autocomplete: "address-level2" %>
    </div>

    <div class="mb-3">
      <%= f.label :postal_code, class: "form-label" %>
      <%= f.text_field :postal_code, class: "form-control", autocomplete: "postal-code" %>
    </div>

    <div class="mb-3">
      <%= f.label :province_id, "Province", class: "form-label" %>
      <%= f.collection_select :province_id, Province.all.order(:name), :id, :name,
          { include_blank: "Select your province" }, { class: "form-select" } %>
    </div>

    <hr class="my-4">
    <h3 class="mb-3">Change Password</h3>

    <div class="mb-3">
      <%= f.label :password, class: "form-label" %>
      <span class="text-muted"><i>(leave blank if you don't want to change it)</i></span>
      <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
      <% if @minimum_password_length %>
        <div class="form-text"><%= @minimum_password_length %> characters minimum</div>
      <% end %>
    </div>

    <div class="mb-3">
      <%= f.label :password_confirmation, class: "form-label" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :current_password, class: "form-label" %>
      <span class="text-muted"><i>(required to confirm any changes)</i></span>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
    </div>

    <div class="d-grid mt-4">
      <%= f.submit "Update Account", class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>

  <hr class="my-4">
  <h3 class="text-danger">Danger Zone</h3>
  <p class="text-muted">Once you cancel your account, there is no going back.</p>
  <%= button_to "Cancel My Account", registration_path(resource_name),
      data: { turbo_confirm: "Are you sure you want to delete your account?" },
      method: :delete, class: "btn btn-outline-danger" %>

  <div class="mt-3">
    <%= link_to "Back", :back, class: "btn btn-secondary" %>
  </div>
</div>