<!-- app/views/categories/show.html.erb -->
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
    <li class="breadcrumb-item"><%= link_to "Categories", categories_path %></li>
    <li class="breadcrumb-item active"><%= @category.name %></li>
  </ol>
</nav>

<h1 class="mb-4"><%= @category.name %></h1>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
  <% @products.each do |product| %>
    <div class="col">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title">
            <%= link_to product.name, product_path(product), class: "text-decoration-none text-dark" %>
          </h5>
          <p class="card-text text-muted small"><%= truncate(product.description, length: 80) %></p>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
          <span class="fw-bold text-success"><%= number_to_currency(product.price) %></span>
          <%= link_to "View Details", product_path(product), class: "btn btn-dark btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="d-flex justify-content-center">
  <%= paginate @products %>
</div>