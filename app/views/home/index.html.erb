<!-- app/views/home/index.html.erb -->
<div class="row mb-4">
  <div class="col">
    <h1 class="display-5 fw-bold">Welcome to Prairie Tech Store</h1>
    <p class="text-muted">Browse our latest products and categories</p>
  </div>
</div>

<!-- Search Forms Row -->
<div class="row g-3 mb-5">

  <!-- Search Products -->
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title">Search Products</h5>
        <%= form_with url: root_path, method: :get, local: true do |f| %>
          <div class="mb-2">
            <%= f.label :product_keyword, "Product Name or Description", class: "form-label" %>
            <%= f.text_field :product_keyword, placeholder: "Search for products...", value: params[:product_keyword], class: "form-control" %>
          </div>
          <div class="mb-2">
            <%= f.label :product_category_id, "Category", class: "form-label" %>
            <%= f.select :product_category_id,
                options_for_select([["All Categories", ""]] + Category.all.map { |c| [c.name, c.id] }, params[:product_category_id]),
                {},
                class: "form-select" %>
          </div>
          <%= f.submit "Search Products", class: "btn btn-dark w-100" %>
        <% end %>
      </div>
    </div>
  </div>



</div>

<!-- Products Grid -->
<h4 class="mb-3">All Products</h4>
<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
  <% @products.each do |product| %>
    <div class="col">
      <div class="card h-100 shadow-sm">
        <% if product.image.attached? %>
          <%= image_tag product.image, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
        <% else %>
          <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
            <span class="text-muted">No Image Available</span>
          </div>
        <% end %>
        <div class="card-body">
          <h5 class="card-title">
            <%= link_to product.name, product_path(product), class: "text-decoration-none text-dark" %>
          </h5>
          <p class="card-text text-muted small"><%= truncate(product.description, length: 80) %></p>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
          <span class="fw-bold text-success fs-5"><%= number_to_currency(product.price) %></span>
          <%= link_to "View Details", product_path(product), class: "btn btn-dark btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-center">
  <%= paginate @products %>
</div>
