<h1>Welcome to Prairie Tech Store Dashboard</h1>

<div class="dashboard-cards" style="display: flex; gap: 20px;">
  <div class="card" style="border:1px solid #ccc; padding:20px; width:200px; text-align:center;">
    <h2><%= @total_products %></h2>
    <p>Products</p>
  </div>

  <div class="card" style="border:1px solid #ccc; padding:20px; width:200px; text-align:center;">
    <h2><%= @total_categories %></h2>
    <p>Categories</p>
  </div>

  <div class="card" style="border:1px solid #ccc; padding:20px; width:200px; text-align:center;">
    <h2><%= @total_orders %></h2>
    <p>Orders</p>
  </div>
</div>