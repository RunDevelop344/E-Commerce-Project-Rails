<div class="container py-4">
  <h2 class="mb-4">My Orders</h2>

  <% if @orders.empty? %>
    <div class="alert alert-info">
      You have no orders yet. <%= link_to "Start shopping", root_path %>
    </div>
  <% else %>
    <% @orders.each do |order| %>
      <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <strong>Order #<%= order.id %></strong>
          <% badge = order.status == "paid" ? "success" : order.status == "shipped" ? "primary" : "warning" %>
          <span class="badge bg-<%= badge %>"><%= order.status&.humanize %></span>
        </div>
        <div class="card-body">
          <p class="text-muted mb-2">Placed on <%= order.created_at.strftime("%B %d, %Y") %></p>
          <table class="table table-bordered mb-3">
            <thead class="table-dark">
              <tr>
                <th>Product</th>
                <th>Qty</th>
                <th>Unit Price</th>
                <th>Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% order.order_items.each do |item| %>
                <tr>
                  <td><%= item.product&.name %></td>
                  <td><%= item.quantity %></td>
                  <td><%= number_to_currency(item.unit_price) %></td>
                  <td><%= number_to_currency(item.subtotal) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <div class="text-end">
            <p class="mb-1">Subtotal: <%= number_to_currency(order.subtotal) %></p>
            <% if order.gst_amount > 0 %><p class="mb-1">GST: <%= number_to_currency(order.gst_amount) %></p><% end %>
            <% if order.pst_amount > 0 %><p class="mb-1">PST: <%= number_to_currency(order.pst_amount) %></p><% end %>
            <% if order.hst_amount > 0 %><p class="mb-1">HST: <%= number_to_currency(order.hst_amount) %></p><% end %>
            <h5 class="fw-bold">Total: <%= number_to_currency(order.total) %></h5>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>