<!-- app/views/products/show.html.erb -->
<div class="row justify-content-center">
  <div class="col-md-8">

    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
        <li class="breadcrumb-item active"><%= @product.name %></li>
      </ol>
    </nav>

    <div class="card shadow">

      <!-- Product Image -->
      <% if @product.image.attached? %>
        <%= image_tag @product.image, class: "card-img-top", style: "max-height: 400px; object-fit: cover;" %>
      <% else %>
        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
          <span class="text-muted fs-5">No Image Available</span>
        </div>
      <% end %>

      <div class="card-body p-4">
        <h1 class="card-title fw-bold mb-1"><%= @product.name %></h1>

        <% if @product.category.present? %>
          <span class="badge bg-secondary mb-3"><%= @product.category.name %></span>
        <% end %>

        <hr>
        <p class="card-text fs-5"><%= @product.description %></p>
        <hr>

        <div class="row mt-3">
          <div class="col-md-6">
            <p class="mb-1 text-muted">Price</p>
            <h3 class="text-success fw-bold"><%= number_to_currency(@product.price) %></h3>
          </div>
          <div class="col-md-6">
            <p class="mb-1 text-muted">Stock Available</p>
            <h3>
              <% if @product.stock_quantity > 0 %>
                <span class="badge bg-success"><%= @product.stock_quantity %> in stock</span>
              <% else %>
                <span class="badge bg-danger">Out of Stock</span>
              <% end %>
            </h3>
          </div>
        </div>

        <div class="mt-4">
        <%= form_with url: add_item_cart_path, method: :post, local: true do |f| %>
        <%= hidden_field_tag :product_id, @product.id %>
        <%= number_field_tag :quantity, 1, min: 1, class: "form-control d-inline w-auto" %>
        <%= f.submit "Add to Cart", class: "btn btn-primary mt-2" %>
        <% end %>
          <%= link_to "← Back to Store", root_path, class: "btn btn-outline-dark" %>
        </div>
      </div>
    </div>

  </div>
</div>