<h1>New Product</h1>

<%= form_with model: @product, local: true, html: { multipart: true } do |f| %>
  <p>
    <%= f.label :name %><br>
    <%= f.text_field :name %>
  </p>

  <p>
    <%= f.label :description %><br>
    <%= f.text_area :description %>
  </p>

  <p>
    <%= f.label :price %><br>
    <%= f.number_field :price %>
  </p>

  <p>
    <%= f.label :stock_quantity %><br>
    <%= f.number_field :stock_quantity %>
  </p>

   <p>
    <%= f.label :image %><br>
    <%= f.file_field :image %>
  </p>


  <p>
    <%= f.submit "Create Product" %>
  </p>
<% end %>