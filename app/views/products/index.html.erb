<div class="row mb-4">
  <div class="col">
    <h1 class="display-6 fw-bold">All Products</h1>
    <p class="text-muted">Browse our full catalogue</p>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <%= form_with url: products_path, method: :get, local: true do |f| %>
          <div class="mb-2">
            <%= f.label :keyword, "Search Products", class: "form-label" %>
            <%= f.text_field :keyword, placeholder: "Search by name or description...",
                value: params[:keyword], class: "form-control" %>
          </div>
          <div class="mb-2">
            <%= f.label :category_id, "Category", class: "form-label" %>
            <%= f.select :category_id,
                options_for_select([["All Categories", ""]] + Category.all.map { |c| [c.name, c.id] },
                params[:category_id]), {}, class: "form-select" %>
          </div>
          <%= f.submit "Search", class: "btn btn-dark w-100" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
  <% if @products.empty? %>
    <div class="col-12">
      <div class="alert alert-info">No products found. <%= link_to "Clear search", products_path %></div>
    </div>
  <% else %>
    <% @products.each do |product| %>
      <%= render "products/product_card", product: product %>
    <% end %>
  <% end %>
</div>

<div class="d-flex justify-content-center">
  <%= paginate @products %>
</div>