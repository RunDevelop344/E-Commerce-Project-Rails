<div class="col">
  <div class="card product-card h-100">
    <% if product.image.attached? %>
      <%= image_tag product.image, alt: product.name, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
    <% else %>
      <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
        <span class="text-muted">No Image Available</span>
      </div>
    <% end %>
    <div class="card-body">
      <h3 class="card-title">
        <%= link_to product.name, product_path(product), class: "text-decoration-none text-dark" %>
      </h3>
      <p class="card-text text-muted small"><%= truncate(product.description, length: 80) %></p>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
      <span class="price"><%= number_to_currency(product.price) %></span>
      <%= link_to "View Details", product_path(product), class: "btn btn-dark btn-sm" %>
    </div>
  </div>
</div>