<h1 class="mb-4">Admin Dashboard</h1>

<%# Stats Cards %>
<div class="row g-4 mb-5">
  <div class="col-md-4">
    <div class="card text-white bg-dark shadow text-center">
      <div class="card-body">
        <h2 class="fw-bold"><%= @total_products %></h2>
        <p>Products</p>
        <%= link_to "Manage", admin_products_path, class: "btn btn-outline-light btn-sm" %>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-white bg-success shadow text-center">
      <div class="card-body">
        <h2 class="fw-bold"><%= @total_categories %></h2>
        <p>Categories</p>
        <%= link_to "Manage", admin_categories_path, class: "btn btn-outline-light btn-sm" %>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-white bg-warning shadow text-center">
      <div class="card-body">
        <h2 class="fw-bold"><%= @total_orders %></h2>
        <p>Orders</p>
        <%= link_to "Manage", admin_orders_path, class: "btn btn-outline-dark btn-sm" %>
      </div>
    </div>
  </div>
</div>

<%# Recent Orders %>
<div class="card shadow mb-5">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="mb-0">Recent Orders</h3>
    <%= link_to "View All", admin_orders_path, class: "btn btn-outline-dark btn-sm" %>
  </div>
  <div class="card-body p-0">
    <table class="table table-striped table-hover align-middle mb-0">
      <thead class="table-dark">
        <tr>
          <th>Order ID</th>
          <th>Customer</th>
          <th>Province</th>
          <th>Total</th>
          <th>Status</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_orders.each do |order| %>
          <tr>
            <td><strong>#<%= order.id %></strong></td>
            <td><%= order.user&.email %></td>
            <td><%= order.province&.name || "N/A" %></td>
            <td><%= number_to_currency(order.total) %></td>
            <td>
              <% badge = order.status == "paid" ? "success" : order.status == "shipped" ? "primary" : "warning" %>
              <span class="badge bg-<%= badge %>"><%= order.status&.humanize %></span>
            </td>
            <td><%= order.created_at.strftime("%b %d, %Y") %></td>
            <td>
              <%= link_to "View", admin_order_path(order), class: "btn btn-info btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%# Recent Products %>
<div class="card shadow">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="mb-0">Recently Added Products</h3>
    <%= link_to "View All", admin_products_path, class: "btn btn-outline-dark btn-sm" %>
  </div>
  <div class="card-body p-0">
    <table class="table table-striped table-hover align-middle mb-0">
      <thead class="table-dark">
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Price</th>
          <th>Stock</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_products.each do |product| %>
          <tr>
            <td>
              <% if product.image.attached? %>
                <%= image_tag product.image.blob.url, alt: product.name, width: 50, class: "rounded" %>
              <% else %>
                <span class="text-muted">No image</span>
              <% end %>
            </td>
            <td><strong><%= product.name %></strong></td>
            <td><%= number_to_currency(product.price) %></td>
            <td>
              <% if product.stock_quantity > 0 %>
                <span class="badge bg-success"><%= product.stock_quantity %></span>
              <% else %>
                <span class="badge bg-danger">Out of stock</span>
              <% end %>
            </td>
            <td>
              <%= link_to "Edit", edit_admin_product_path(product), class: "btn btn-warning btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
