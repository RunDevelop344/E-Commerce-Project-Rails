<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow">
      <div class="card-body p-4">
        <h1 class="mb-3">Order #<%= @order.id %></h1>
        <hr>
        <p><strong>User ID:</strong> <%= @order.user_id %></p>
        <p><strong>Total:</strong> <%= number_to_currency(@order.total) %></p>
        <hr>
        <%= link_to "Edit", edit_admin_order_path(@order), class: "btn btn-warning" %>
        <%= link_to "Back to Orders", admin_orders_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>