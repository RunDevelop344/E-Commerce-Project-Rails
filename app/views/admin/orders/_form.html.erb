<%= form_with model: [:admin, order], local: true do |f| %>
  <% if order.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% order.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :status, class: "form-label" %>
    <%= f.select :status, ["pending", "processing", "shipped", "delivered", "cancelled"],
        { prompt: "Select status" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :total_price, class: "form-label" %>
    <%= f.number_field :total_price, step: 0.01, class: "form-control" %>
  </div>

  <%= f.submit class: "btn btn-dark w-100" %>
<% end %>