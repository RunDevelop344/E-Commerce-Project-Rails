<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Orders</h1>
  <%= link_to "New Order", new_admin_order_path, class: "btn btn-dark" %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Order ID</th>
        <th>User ID</th>
        <th>Total</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td>#<%= order.id %></td>
          <td><%= order.user_id %></td>
          <td><%= number_to_currency(order.total) %></td>
          <td>
            <%= link_to "Show", admin_order_path(order), class: "btn btn-info btn-sm" %>
            <%= link_to "Edit", edit_admin_order_path(order), class: "btn btn-warning btn-sm" %>
            <%= button_to "Delete", admin_order_path(order), method: :delete,
                data: { turbo_confirm: "Are you sure?" },
                class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>