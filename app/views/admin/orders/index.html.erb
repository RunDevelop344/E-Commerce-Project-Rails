<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Orders</h1>
</div>
<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Province</th>
        <th>Subtotal</th>
        <th>Taxes</th>
        <th>Total</th>
        <th>Status</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td><strong>#<%= order.id %></strong></td>
          <td><%= order.user&.email %></td>
          <td><%= order.province&.name || "N/A" %></td>
          <td><%= number_to_currency(order.subtotal) %></td>
          <td>
            <small>
              <% if order.gst_amount > 0 %>GST: <%= number_to_currency(order.gst_amount) %><br><% end %>
              <% if order.pst_amount > 0 %>PST: <%= number_to_currency(order.pst_amount) %><br><% end %>
              <% if order.hst_amount > 0 %>HST: <%= number_to_currency(order.hst_amount) %><% end %>
            </small>
          </td>
          <td><strong><%= number_to_currency(order.total) %></strong></td>
          <td>
            <% badge = order.status == "paid" ? "success" : order.status == "shipped" ? "primary" : "warning" %>
            <span class="badge bg-<%= badge %>"><%= order.status&.humanize %></span>
          </td>
          <td><%= order.created_at.strftime("%b %d, %Y") %></td>
          <td>
            <%= link_to "View", admin_order_path(order), class: "btn btn-info btn-sm" %>
            <%= link_to "Edit", edit_admin_order_path(order), class: "btn btn-warning btn-sm" %>
            <%= button_to "Delete", admin_order_path(order), method: :delete,
                data: { turbo_confirm: "Are you sure?" },
                class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>