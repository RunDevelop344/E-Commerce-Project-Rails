<h1>Orders</h1>

<%= link_to "New Order", new_order_path, class: "btn btn-primary mb-3" %>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Customer ID</th>
      <th>Status</th>
      <th>Total Price</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @orders.each do |order| %>
      <tr>
        <td><%= order.user_id %></td>
        <td>$<%= order.total %></td>
        <td>
          <%= link_to "Show", order_path(order), class: "btn btn-info btn-sm" %>
          <%= link_to "Edit", edit_order_path(order), class: "btn btn-warning btn-sm" %>
          <%= link_to "Delete", order_path(order), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>