<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Products</h1>
  <%= link_to "New Product", new_admin_product_path, class: "btn btn-dark" %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Image</th>
        <th>Name</th>
        <th>Price</th>
        <th>Stock</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr>
          <td>
            <% if product.image.attached? %>
              <%= image_tag product.image, width: 60, class: "rounded" %>
            <% else %>
              <span class="text-muted">No image</span>
            <% end %>
          </td>
          <td><strong><%= product.name %></strong></td>
          <td><%= number_to_currency(product.price) %></td>
          <td>
            <% if product.stock_quantity > 0 %>
              <span class="badge bg-success"><%= product.stock_quantity %></span>
            <% else %>
              <span class="badge bg-danger">Out of stock</span>
            <% end %>
          </td>
          <td>
            <%= link_to "Edit", edit_admin_product_path(product), class: "btn btn-warning btn-sm" %>
            <%= button_to "Delete", admin_product_path(product), method: :delete,
                data: { turbo_confirm: "Are you sure?" },
                class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>