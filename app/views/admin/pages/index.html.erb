<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Pages</h1>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Page</th>
        <th>Title</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @pages.each do |page| %>
        <tr>
          <td><strong><%= page.slug %></strong></td>
          <td><%= page.title %></td>
          <td>
            <%= link_to "Edit", edit_admin_page_path(page), class: "btn btn-warning btn-sm" %>
            <%= link_to "View", page.slug == "about" ? about_path : contact_path,
                class: "btn btn-info btn-sm", target: "_blank" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>